# Copia este archivo a .env y completa los valores para desarrollo local.
# En producción (Render) estas variables se configuran en el dashboard o render.yaml.

# Django
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=True
ALLOWED_HOSTS=*

# Base de datos (dejar vacío usa SQLite local)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS — orígenes permitidos del frontend (dejar vacío permite todos en DEBUG=True)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rutas (dejar vacío usa las rutas locales por defecto)
# MEDIA_ROOT=/ruta/a/media
# AI_MODEL_DIR=/ruta/a/models

# TensorFlow — reducir ruido en logs
TF_CPP_MIN_LOG_LEVEL=2
TF_ENABLE_ONEDNN_OPTS=0
